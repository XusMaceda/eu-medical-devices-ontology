    <owl:Class rdf:about="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#CategoryConcept">
        <rdfs:comment>Controlled concept representing a category used to classify risks.</rdfs:comment>
        <rdfs:label>Risk category concept</rdfs:label>
    </owl:Class>
    


    <!-- http://www.uoc.edu/knowledgeManagement/eu-medical-devices#CompetentAuthority -->


    <owl:Class rdf:about="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#CompetentAuthority">
        <rdfs:subClassOf rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#Organization"/>
        <rdfs:comment>Public authority responsible for medical device oversight in a country.</rdfs:comment>
        <rdfs:label>Competent authority</rdfs:label>
    </owl:Class>
    


    <!-- http://www.uoc.edu/knowledgeManagement/eu-medical-devices#ContaminationRisk -->


    <owl:Class rdf:about="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#ContaminationRisk">
        <rdfs:subClassOf rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#Risk"/>
        <rdfs:comment>Risk related to contamination of device components, reagents or materials.</rdfs:comment>
        <rdfs:label>Contamination risk</rdfs:label>
    </owl:Class>
    


    <!-- http://www.uoc.edu/knowledgeManagement/eu-medical-devices#CorrectedIncident -->


    <owl:Class rdf:about="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#CorrectedIncident">
        <rdfs:comment>Incident inferred as having at least one associated corrective action.</rdfs:comment>
        <rdfs:label>Corrected incident</rdfs:label>
    </owl:Class>
    


    <!-- http://www.uoc.edu/knowledgeManagement/eu-medical-devices#Country -->


    <owl:Class rdf:about="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#Country">
        <rdfs:comment>Nation in which a manufacturer, incident or corrective action is registered.</rdfs:comment>
        <rdfs:label>Country</rdfs:label>
    </owl:Class>
    


    <!-- http://www.uoc.edu/knowledgeManagement/eu-medical-devices#CybersecurityRisk -->


    <owl:Class rdf:about="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#CybersecurityRisk">
        <rdfs:subClassOf rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#Risk"/>
        <rdfs:comment>Risks arising from cybersecurity failures.</rdfs:comment>
        <rdfs:label>Cybersecuty risk</rdfs:label>
    </owl:Class>
    


    <!-- http://www.uoc.edu/knowledgeManagement/eu-medical-devices#Device -->


    <owl:Class rdf:about="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#Device">
        <rdfs:subClassOf rdf:resource="http://schema.org/MedicalDevice"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#hasDeviceType"/>
                <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minQualifiedCardinality>
                <owl:onClass rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#DeviceType"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#hasManufacturer"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#Manufacturer"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#hasRegulatoryFramework"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#RegulatoryFramework"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#hasRiskClass"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#RiskClass"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://schema.org/name"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#intendedPurpose"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#isActive"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#isImplantable"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#isReusable"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#udiDI"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#token"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>Medical device placed on the European market under MDR or IVDR regulations.</rdfs:comment>
        <rdfs:label>Device</rdfs:label>
    </owl:Class>
    


    <!-- http://www.uoc.edu/knowledgeManagement/eu-medical-devices#DeviceType -->


    <owl:Class rdf:about="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#DeviceType">
        <rdfs:comment>Controlled classification describing the functional or structural type of device.</rdfs:comment>
        <rdfs:label>Device type</rdfs:label>
    </owl:Class>
    


    <!-- http://www.uoc.edu/knowledgeManagement/eu-medical-devices#DiagnosticRisk -->


    <owl:Class rdf:about="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#DiagnosticRisk">
        <rdfs:subClassOf rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#Risk"/>
        <rdfs:comment>Risk related to incorrect diagnostic results or interpretation.</rdfs:comment>
        <rdfs:label>Diagnostic risk</rdfs:label>
    </owl:Class>
    


    <!-- http://www.uoc.edu/knowledgeManagement/eu-medical-devices#FSCAStatusConcept -->


    <owl:Class rdf:about="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#FSCAStatusConcept">
        <rdfs:comment>Controlled concept representing the status of a field safety corrective action.</rdfs:comment>
        <rdfs:label>FCSA status concept</rdfs:label>
    </owl:Class>
    


    <!-- http://www.uoc.edu/knowledgeManagement/eu-medical-devices#FieldSafetyCorrectiveAction -->


    <owl:Class rdf:about="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#FieldSafetyCorrectiveAction">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#correctiveActionFor"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#Incident"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#hasFSCAStatus"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#FSCAStatusConcept"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://schema.org/description"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#actionDate"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#devicesAffected"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#eudamedFSCARef"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#token"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#scope"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#closureDate"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>Corrective measure taken to reduce risks associated with marketed devices.</rdfs:comment>
        <rdfs:label>Field safety corrective action</rdfs:label>
    </owl:Class>
    


    <!-- http://www.uoc.edu/knowledgeManagement/eu-medical-devices#HighRiskDevice -->


    <owl:Class rdf:about="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#HighRiskDevice">
        <rdfs:comment>Device inferred as high risk according to its regulatory risk class.</rdfs:comment>
        <rdfs:label>High-risk device</rdfs:label>
    </owl:Class>
    


    <!-- http://www.uoc.edu/knowledgeManagement/eu-medical-devices#IVDDevice -->


    <owl:Class rdf:about="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#IVDDevice">
        <rdfs:subClassOf rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#Device"/>
        <owl:disjointWith rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#MDRDevice"/>
        <rdfs:comment>In vitro diagnostic device regulated under the IVDR regulation.</rdfs:comment>
        <rdfs:label>IVD device</rdfs:label>
    </owl:Class>
    


    <!-- http://www.uoc.edu/knowledgeManagement/eu-medical-devices#InSituCorrection -->


    <owl:Class rdf:about="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#InSituCorrection">
        <rdfs:subClassOf rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#FieldSafetyCorrectiveAction"/>
        <owl:disjointWith rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#Recall"/>
        <owl:disjointWith rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#SafetyAlert"/>
        <owl:disjointWith rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#UserNotice"/>
        <rdfs:comment>Corrective action applied while the device remains in use or in place.</rdfs:comment>
        <rdfs:label>In situ correction</rdfs:label>
    </owl:Class>
    


    <!-- http://www.uoc.edu/knowledgeManagement/eu-medical-devices#Incident -->


    <owl:Class rdf:about="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#Incident">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#involvesDevice"/>
                <owl:someValuesFrom rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#Device"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#associatedRisk"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#Risk"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#isReportedBy"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#Manufacturer"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#reportedInCountry"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#Country"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#affectedPatient"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onClass rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#Patient"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://schema.org/description"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#detectionDate"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#eudamedIncidentRef"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#token"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#eventDate"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#outcome"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#reportDate"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>Reported event involving a medical device that may cause harm or malfunction.</rdfs:comment>
        <rdfs:label>Incident</rdfs:label>
    </owl:Class>
    


    <!-- http://www.uoc.edu/knowledgeManagement/eu-medical-devices#InjuryRisk -->


    <owl:Class rdf:about="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#InjuryRisk">
        <rdfs:subClassOf rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#Risk"/>
        <rdfs:comment>Risk that may result in patient injury or deterioration of health.</rdfs:comment>
        <rdfs:label>Injury risk</rdfs:label>
    </owl:Class>
    


    <!-- http://www.uoc.edu/knowledgeManagement/eu-medical-devices#InterferenceRisk -->


    <owl:Class rdf:about="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#InterferenceRisk">
        <rdfs:subClassOf rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#Risk"/>
        <rdfs:comment>Risk related to electromagnetic, imaging or operational interference.</rdfs:comment>
        <rdfs:label>Interference risk</rdfs:label>
    </owl:Class>
    


    <!-- http://www.uoc.edu/knowledgeManagement/eu-medical-devices#MDRDevice -->


    <owl:Class rdf:about="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#MDRDevice">
        <rdfs:subClassOf rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#Device"/>
        <rdfs:comment>Medical device regulated under the European MDR regulation.</rdfs:comment>
        <rdfs:label>MDR Device</rdfs:label>
    </owl:Class>
    


    <!-- http://www.uoc.edu/knowledgeManagement/eu-medical-devices#MalfunctionRisk -->


    <owl:Class rdf:about="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#MalfunctionRisk">
        <rdfs:subClassOf rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#Risk"/>
        <rdfs:comment>Risk related to device malfunction or failure to perform as intended.</rdfs:comment>
        <rdfs:label>Malfunction risk</rdfs:label>
    </owl:Class>
    


    <!-- http://www.uoc.edu/knowledgeManagement/eu-medical-devices#Manufacturer -->


    <owl:Class rdf:about="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#Manufacturer">
        <rdfs:subClassOf rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#Organization"/>
        <rdfs:subClassOf>
            <owl:Restriction>
