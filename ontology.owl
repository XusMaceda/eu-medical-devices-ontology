                                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#IndividualPropertyAtom"/>
                                <swrl:propertyPredicate rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#hasRiskClass"/>
                                <swrl:argument1 rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#d"/>
                                <swrl:argument2 rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#ClassIII"/>
                            </rdf:Description>
                        </rdf:first>
                        <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
                    </rdf:Description>
                </rdf:rest>
            </rdf:Description>
        </swrl:body>
        <swrl:head>
            <rdf:Description>
                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                <rdf:first>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#ClassAtom"/>
