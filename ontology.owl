<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#"
     xml:base="http://www.uoc.edu/knowledgeManagement/eu-medical-devices"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:swrl="http://www.w3.org/2003/11/swrl#"
     xmlns:swrla="http://swrl.stanford.edu/ontologies/3.3/swrla.owl#"
     xmlns:swrlb="http://www.w3.org/2003/11/swrlb#"
     xmlns:terms="http://purl.org/dc/terms/"
     xmlns:schema="http://schema.org/"
     xmlns:eu-medical-devices="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#">
    <owl:Ontology rdf:about="http://www.uoc.edu/knowledgeManagement/eu-medical-devices">
        <owl:versionIRI rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices/1.0.0"/>
        <terms:creator>Jesús Maceda Martinez</terms:creator>
        <terms:description>An OWL ontology for representing medical devices marketed in the European Union, including manufacturers, device types, regulatory frameworks, risk classes, known risks, incidents, affected patients and field safety corrective actions. The ontology is populated from CSV datasets and supports semantic reasoning through SWRL rules and external RDF links.</terms:description>
        <terms:title>EU Medical Devices Ontology</terms:title>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://purl.org/dc/terms/creator -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/creator"/>
    


    <!-- http://purl.org/dc/terms/description -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/description"/>
    


    <!-- http://purl.org/dc/terms/title -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/title"/>
    


    <!-- http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled -->


    <owl:AnnotationProperty rdf:about="http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Datatypes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.w3.org/2001/XMLSchema#date -->


    <rdfs:Datatype rdf:about="http://www.w3.org/2001/XMLSchema#date"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.uoc.edu/knowledgeManagement/eu-medical-devices#affectedPatient -->


    <owl:ObjectProperty rdf:about="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#affectedPatient">
        <rdfs:domain rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#Incident"/>
        <rdfs:range rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#Patient"/>
        <rdfs:comment>Relates an incident to the affected patient.</rdfs:comment>
        <rdfs:label>affected patient</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.uoc.edu/knowledgeManagement/eu-medical-devices#associatedRisk -->


    <owl:ObjectProperty rdf:about="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#associatedRisk">
        <rdfs:domain rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#Incident"/>
        <rdfs:range rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#Risk"/>
        <rdfs:comment>Links an incident to the related risk.</rdfs:comment>
        <rdfs:label>associated risk</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.uoc.edu/knowledgeManagement/eu-medical-devices#correctiveActionFor -->


    <owl:ObjectProperty rdf:about="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#correctiveActionFor">
        <owl:inverseOf rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#hasCorrectiveAction"/>
        <rdfs:domain rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#FieldSafetyCorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#Incident"/>
        <rdfs:comment>Relates a corrective action to the incident that originated it.</rdfs:comment>
        <rdfs:label>corrective action for</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.uoc.edu/knowledgeManagement/eu-medical-devices#hasCompetentAuthority -->


    <owl:ObjectProperty rdf:about="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#hasCompetentAuthority">
        <rdfs:domain rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#CompetentAuthority"/>
        <rdfs:comment>Relates a manufacturer to the competent authority responsible for oversight.</rdfs:comment>
        <rdfs:label>has competent authority</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.uoc.edu/knowledgeManagement/eu-medical-devices#hasCorrectiveAction -->


    <owl:ObjectProperty rdf:about="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#hasCorrectiveAction">
        <rdfs:domain rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#Incident"/>
        <rdfs:range rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#FieldSafetyCorrectiveAction"/>
        <rdfs:comment>Links an incident to corrective actions taken.</rdfs:comment>
        <rdfs:label>has corrective action</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.uoc.edu/knowledgeManagement/eu-medical-devices#hasDeviceType -->


    <owl:ObjectProperty rdf:about="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#hasDeviceType">
        <rdfs:domain rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#Device"/>
        <rdfs:range rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#DeviceType"/>
        <rdfs:comment>Relates a device to one or more controlled device types.</rdfs:comment>
        <rdfs:label>has device type</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.uoc.edu/knowledgeManagement/eu-medical-devices#hasFSCAStatus -->


    <owl:ObjectProperty rdf:about="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#hasFSCAStatus">
        <rdfs:domain rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#FieldSafetyCorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#FSCAStatusConcept"/>
        <rdfs:comment>Relates a field safety corrective action to its current status.</rdfs:comment>
        <rdfs:label>has FSCA status</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.uoc.edu/knowledgeManagement/eu-medical-devices#hasIncident -->


    <owl:ObjectProperty rdf:about="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#hasIncident">
        <owl:inverseOf rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#involvesDevice"/>
        <rdfs:domain rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#Device"/>
        <rdfs:range rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#Incident"/>
        <rdfs:comment>Relates a device to incidents in which the device was involved.</rdfs:comment>
        <rdfs:label>has incident</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.uoc.edu/knowledgeManagement/eu-medical-devices#hasKnownRisk -->


    <owl:ObjectProperty rdf:about="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#hasKnownRisk">
        <owl:inverseOf rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#impactsDeviceType"/>
        <rdfs:domain rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#DeviceType"/>
        <rdfs:range rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#Risk"/>
        <rdfs:comment>Relates a device type to known associated risks.</rdfs:comment>
        <rdfs:label>has known risk</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.uoc.edu/knowledgeManagement/eu-medical-devices#hasManufacturer -->


    <owl:ObjectProperty rdf:about="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#hasManufacturer">
        <owl:inverseOf rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#manufactures"/>
        <rdfs:domain rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#Device"/>
        <rdfs:range rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#Manufacturer"/>
        <rdfs:comment>Relates a device to its legal manufacturer.</rdfs:comment>
        <rdfs:label>has manufacturer</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.uoc.edu/knowledgeManagement/eu-medical-devices#hasRegulatoryFramework -->


    <owl:ObjectProperty rdf:about="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#hasRegulatoryFramework">
        <rdfs:domain rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#Device"/>
        <rdfs:range rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#RegulatoryFramework"/>
        <rdfs:comment>Relates a device to the regulatory framework under which it is registered.</rdfs:comment>
        <rdfs:label>has regulatory framework</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.uoc.edu/knowledgeManagement/eu-medical-devices#hasRiskCategory -->


    <owl:ObjectProperty rdf:about="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#hasRiskCategory">
        <rdfs:domain rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#Risk"/>
        <rdfs:range rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#CategoryConcept"/>
        <rdfs:comment>Relates a risk to its controlled risk category.</rdfs:comment>
        <rdfs:label>has risk category</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.uoc.edu/knowledgeManagement/eu-medical-devices#hasRiskClass -->


    <owl:ObjectProperty rdf:about="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#hasRiskClass">
        <rdfs:domain rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#Device"/>
        <rdfs:range rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#RiskClass"/>
        <rdfs:comment>Relates a device to its regulatory risk classification.</rdfs:comment>
        <rdfs:label>has risk class</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.uoc.edu/knowledgeManagement/eu-medical-devices#hasRiskProbability -->


    <owl:ObjectProperty rdf:about="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#hasRiskProbability">
        <rdfs:domain rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#Risk"/>
        <rdfs:range rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#ProbabilityConcept"/>
        <rdfs:comment>Relates a risk to its probability level.</rdfs:comment>
        <rdfs:label>has risk probability</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.uoc.edu/knowledgeManagement/eu-medical-devices#hasRiskSeverity -->


    <owl:ObjectProperty rdf:about="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#hasRiskSeverity">
        <rdfs:domain rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#Risk"/>
        <rdfs:range rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#SeverityConcept"/>
        <rdfs:comment>Relates a risk to its severity level.</rdfs:comment>
        <rdfs:label>has risk severity</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.uoc.edu/knowledgeManagement/eu-medical-devices#impactsDeviceType -->


    <owl:ObjectProperty rdf:about="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#impactsDeviceType">
        <rdfs:domain rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#Risk"/>
        <rdfs:range rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#DeviceType"/>
        <rdfs:comment>Indicates the device type affected by a risk..</rdfs:comment>
        <rdfs:label>impacts device type</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.uoc.edu/knowledgeManagement/eu-medical-devices#involvesDevice -->


    <owl:ObjectProperty rdf:about="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#involvesDevice">
        <rdfs:domain rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#Incident"/>
        <rdfs:range rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#Device"/>
        <rdfs:comment>Links an incident to the device involved.</rdfs:comment>
        <rdfs:label>involves device</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.uoc.edu/knowledgeManagement/eu-medical-devices#involvesManufacturer -->


    <owl:ObjectProperty rdf:about="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#involvesManufacturer">
        <rdfs:domain rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#Incident"/>
        <rdfs:range rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#Manufacturer"/>
        <rdfs:comment>Inferred relation linking an incident to the manufacturer of the involved device.</rdfs:comment>
        <rdfs:label>involves manufacturer</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.uoc.edu/knowledgeManagement/eu-medical-devices#isReportedBy -->


    <owl:ObjectProperty rdf:about="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#isReportedBy">
        <rdfs:domain rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#Incident"/>
        <rdfs:range rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#Manufacturer"/>
        <rdfs:comment>Relates an incident to the manufacturer that reported it.</rdfs:comment>
        <rdfs:label>is reported by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.uoc.edu/knowledgeManagement/eu-medical-devices#locatedInCountry -->


    <owl:ObjectProperty rdf:about="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#locatedInCountry">
        <rdfs:domain rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#Organization"/>
        <rdfs:range rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#Country"/>
        <rdfs:comment>Relates an organization to the country where it is registered or located.</rdfs:comment>
        <rdfs:label>located in country</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.uoc.edu/knowledgeManagement/eu-medical-devices#manufactures -->


    <owl:ObjectProperty rdf:about="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#manufactures">
        <rdfs:domain rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#Device"/>
        <rdfs:comment>Relates a manufacturer to devices it manufactures.</rdfs:comment>
        <rdfs:label>manufactures</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.uoc.edu/knowledgeManagement/eu-medical-devices#reportedInCountry -->


    <owl:ObjectProperty rdf:about="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#reportedInCountry">
        <rdfs:domain rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#Incident"/>
        <rdfs:range rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#Country"/>
        <rdfs:comment>Relates an incident to the country where it was reported.</rdfs:comment>
        <rdfs:label>reported in country</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://schema.org/description -->


    <owl:DatatypeProperty rdf:about="http://schema.org/description">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Textual description of the entity.</rdfs:comment>
        <rdfs:label>description</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://schema.org/email -->


    <owl:DatatypeProperty rdf:about="http://schema.org/email"/>
    


    <!-- http://schema.org/gender -->


    <owl:DatatypeProperty rdf:about="http://schema.org/gender"/>
    


    <!-- http://schema.org/identifier -->


    <owl:DatatypeProperty rdf:about="http://schema.org/identifier"/>
    


    <!-- http://schema.org/name -->


    <owl:DatatypeProperty rdf:about="http://schema.org/name">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Human-readable name of the entity.</rdfs:comment>
        <rdfs:label>name</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.uoc.edu/knowledgeManagement/eu-medical-devices#actionDate -->


    <owl:DatatypeProperty rdf:about="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#actionDate">
        <rdfs:domain rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#FieldSafetyCorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:comment>Date on which the corrective action was initiated.</rdfs:comment>
        <rdfs:label>action date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.uoc.edu/knowledgeManagement/eu-medical-devices#authorizationNumber -->


    <owl:DatatypeProperty rdf:about="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#authorizationNumber">
        <rdfs:subPropertyOf rdf:resource="http://schema.org/identifier"/>
        <rdfs:domain rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#token"/>
        <rdfs:comment>Authorization or registration number assigned to a manufacturer.</rdfs:comment>
        <rdfs:label>authorization number</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.uoc.edu/knowledgeManagement/eu-medical-devices#closureDate -->


    <owl:DatatypeProperty rdf:about="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#closureDate">
        <rdfs:domain rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#FieldSafetyCorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:comment>Date on which the corrective action was closed.</rdfs:comment>
        <rdfs:label>clusure date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.uoc.edu/knowledgeManagement/eu-medical-devices#detectionDate -->


    <owl:DatatypeProperty rdf:about="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#detectionDate">
        <rdfs:domain rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:comment>Date on which the incident was detected.</rdfs:comment>
        <rdfs:label>detection date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.uoc.edu/knowledgeManagement/eu-medical-devices#devicesAffected -->


    <owl:DatatypeProperty rdf:about="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#devicesAffected">
        <rdfs:domain rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#FieldSafetyCorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Number or textual quantity of devices affected by a corrective action.</rdfs:comment>
        <rdfs:label>devices affected</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.uoc.edu/knowledgeManagement/eu-medical-devices#eudamedFSCARef -->


    <owl:DatatypeProperty rdf:about="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#eudamedFSCARef">
        <rdfs:subPropertyOf rdf:resource="http://schema.org/identifier"/>
        <rdfs:domain rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#FieldSafetyCorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#token"/>
        <rdfs:comment>Reference identifier assigned to a field safety corrective action.</rdfs:comment>
        <rdfs:label>EUDAMED FSCA reference</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.uoc.edu/knowledgeManagement/eu-medical-devices#eudamedIncidentRef -->


    <owl:DatatypeProperty rdf:about="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#eudamedIncidentRef">
        <rdfs:subPropertyOf rdf:resource="http://schema.org/identifier"/>
        <rdfs:domain rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#token"/>
        <rdfs:comment>Reference identifier assigned to an incident report.</rdfs:comment>
        <rdfs:label>EUDAMED incident reference</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.uoc.edu/knowledgeManagement/eu-medical-devices#eudamedSRN -->


    <owl:DatatypeProperty rdf:about="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#eudamedSRN">
        <rdfs:domain rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#token"/>
        <rdfs:comment>Single Registration Number assigned to an economic operator in EUDAMED.</rdfs:comment>
        <rdfs:label>EUDAMED SRN</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.uoc.edu/knowledgeManagement/eu-medical-devices#eventDate -->


    <owl:DatatypeProperty rdf:about="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#eventDate">
        <rdfs:domain rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:comment>Date on which the incident occurred.</rdfs:comment>
        <rdfs:label>event date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.uoc.edu/knowledgeManagement/eu-medical-devices#imdrfCode -->


    <owl:DatatypeProperty rdf:about="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#imdrfCode">
        <rdfs:subPropertyOf rdf:resource="http://schema.org/identifier"/>
        <rdfs:domain rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#Risk"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#token"/>
        <rdfs:comment>Code identifying a risk according to an IMDRF-style classification.</rdfs:comment>
        <rdfs:label>IMDRF code</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.uoc.edu/knowledgeManagement/eu-medical-devices#intendedPurpose -->


    <owl:DatatypeProperty rdf:about="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#intendedPurpose">
        <rdfs:domain rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#Device"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Intended medical purpose or use of the device.</rdfs:comment>
        <rdfs:label>intended purpose</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.uoc.edu/knowledgeManagement/eu-medical-devices#isActive -->


    <owl:DatatypeProperty rdf:about="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#isActive">
        <rdfs:domain rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#Device"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment>Indicates whether the device is an active device according to the source data.</rdfs:comment>
        <rdfs:label>is active</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.uoc.edu/knowledgeManagement/eu-medical-devices#isImplantable -->


    <owl:DatatypeProperty rdf:about="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#isImplantable">
        <rdfs:domain rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#Device"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment>Indicates whether the device is intended to be implanted in the human body.</rdfs:comment>
        <rdfs:label>is implantable</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.uoc.edu/knowledgeManagement/eu-medical-devices#isReusable -->


    <owl:DatatypeProperty rdf:about="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#isReusable">
        <rdfs:domain rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#Device"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment>Indicates whether the device is intended for multiple uses.</rdfs:comment>
        <rdfs:label>is reusable</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.uoc.edu/knowledgeManagement/eu-medical-devices#outcome -->


    <owl:DatatypeProperty rdf:about="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#outcome">
        <rdfs:domain rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Textual description of the incident outcome.</rdfs:comment>
        <rdfs:label>outcome</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.uoc.edu/knowledgeManagement/eu-medical-devices#patientAge -->


    <owl:DatatypeProperty rdf:about="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#patientAge">
        <rdfs:domain rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#Patient"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment>Age of the affected patient in years.</rdfs:comment>
        <rdfs:label>patient age</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.uoc.edu/knowledgeManagement/eu-medical-devices#reportDate -->


    <owl:DatatypeProperty rdf:about="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#reportDate">
        <rdfs:domain rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:comment>Date on which the incident was officially reported.</rdfs:comment>
        <rdfs:label>report date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.uoc.edu/knowledgeManagement/eu-medical-devices#scope -->


    <owl:DatatypeProperty rdf:about="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#scope">
        <rdfs:domain rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#FieldSafetyCorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Description of products, lots, units or users covered by a corrective action.</rdfs:comment>
        <rdfs:label>scope</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.uoc.edu/knowledgeManagement/eu-medical-devices#udiDI -->


    <owl:DatatypeProperty rdf:about="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#udiDI">
        <rdfs:subPropertyOf rdf:resource="http://schema.org/identifier"/>
        <rdfs:domain rdf:resource="http://www.uoc.edu/knowledgeManagement/eu-medical-devices#Device"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#token"/>
        <rdfs:comment>Unique Device Identifier - Device Identifier.</rdfs:comment>
        <rdfs:label>UDI-DI</rdfs:label>
    </owl:DatatypeProperty>
    


