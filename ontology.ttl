@prefix : <http://www.uoc.edu/knowledgeManagement/eu-medical-devices#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://www.uoc.edu/knowledgeManagement/eu-medical-devices#> .

<http://www.uoc.edu/knowledgeManagement/eu-medical-devices> rdf:type owl:Ontology ;
                                                             owl:versionIRI <http://www.uoc.edu/knowledgeManagement/eu-medical-devices/1.0.0> ;
                                                             <http://purl.org/dc/terms/creator> "Jesús Maceda Martinez" ;
                                                             <http://purl.org/dc/terms/description> "An OWL ontology for representing medical devices marketed in the European Union, including manufacturers, device types, regulatory frameworks, risk classes, known risks, incidents, affected patients and field safety corrective actions. The ontology is populated from CSV datasets and supports semantic reasoning through SWRL rules and external RDF links." ;
                                                             <http://purl.org/dc/terms/title> "EU Medical Devices Ontology" .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/terms/creator
<http://purl.org/dc/terms/creator> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/description
<http://purl.org/dc/terms/description> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/title
<http://purl.org/dc/terms/title> rdf:type owl:AnnotationProperty .


###  http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled
<http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled> rdf:type owl:AnnotationProperty .


#################################################################
#    Datatypes
#################################################################

###  http://www.w3.org/2001/XMLSchema#date
xsd:date rdf:type rdfs:Datatype .


#################################################################
#    Object Properties
#################################################################

###  http://www.uoc.edu/knowledgeManagement/eu-medical-devices#affectedPatient
:affectedPatient rdf:type owl:ObjectProperty ;
                 rdfs:domain :Incident ;
                 rdfs:range :Patient ;
                 rdfs:comment "Relates an incident to the affected patient." ;
                 rdfs:label "affected patient" .


###  http://www.uoc.edu/knowledgeManagement/eu-medical-devices#associatedRisk
:associatedRisk rdf:type owl:ObjectProperty ;
                rdfs:domain :Incident ;
                rdfs:range :Risk ;
                rdfs:comment "Links an incident to the related risk." ;
                rdfs:label "associated risk" .


###  http://www.uoc.edu/knowledgeManagement/eu-medical-devices#correctiveActionFor
:correctiveActionFor rdf:type owl:ObjectProperty ;
                     owl:inverseOf :hasCorrectiveAction ;
                     rdfs:domain :FieldSafetyCorrectiveAction ;
                     rdfs:range :Incident ;
                     rdfs:comment "Relates a corrective action to the incident that originated it." ;
                     rdfs:label "corrective action for" .


###  http://www.uoc.edu/knowledgeManagement/eu-medical-devices#hasCompetentAuthority
:hasCompetentAuthority rdf:type owl:ObjectProperty ;
                       rdfs:domain :Manufacturer ;
                       rdfs:range :CompetentAuthority ;
                       rdfs:comment "Relates a manufacturer to the competent authority responsible for oversight." ;
                       rdfs:label "has competent authority" .


###  http://www.uoc.edu/knowledgeManagement/eu-medical-devices#hasCorrectiveAction
:hasCorrectiveAction rdf:type owl:ObjectProperty ;
                     rdfs:domain :Incident ;
                     rdfs:range :FieldSafetyCorrectiveAction ;
                     rdfs:comment "Links an incident to corrective actions taken." ;
                     rdfs:label "has corrective action" .


###  http://www.uoc.edu/knowledgeManagement/eu-medical-devices#hasDeviceType
:hasDeviceType rdf:type owl:ObjectProperty ;
               rdfs:domain :Device ;
               rdfs:range :DeviceType ;
               rdfs:comment "Relates a device to one or more controlled device types." ;
               rdfs:label "has device type" .


###  http://www.uoc.edu/knowledgeManagement/eu-medical-devices#hasFSCAStatus
:hasFSCAStatus rdf:type owl:ObjectProperty ;
               rdfs:domain :FieldSafetyCorrectiveAction ;
               rdfs:range :FSCAStatusConcept ;
               rdfs:comment "Relates a field safety corrective action to its current status." ;
               rdfs:label "has FSCA status" .


###  http://www.uoc.edu/knowledgeManagement/eu-medical-devices#hasIncident
:hasIncident rdf:type owl:ObjectProperty ;
             owl:inverseOf :involvesDevice ;
             rdfs:domain :Device ;
             rdfs:range :Incident ;
             rdfs:comment "Relates a device to incidents in which the device was involved." ;
             rdfs:label "has incident" .


###  http://www.uoc.edu/knowledgeManagement/eu-medical-devices#hasKnownRisk
:hasKnownRisk rdf:type owl:ObjectProperty ;
              owl:inverseOf :impactsDeviceType ;
              rdfs:domain :DeviceType ;
              rdfs:range :Risk ;
              rdfs:comment "Relates a device type to known associated risks." ;
              rdfs:label "has known risk" .


###  http://www.uoc.edu/knowledgeManagement/eu-medical-devices#hasManufacturer
:hasManufacturer rdf:type owl:ObjectProperty ;
                 owl:inverseOf :manufactures ;
                 rdfs:domain :Device ;
                 rdfs:range :Manufacturer ;
                 rdfs:comment "Relates a device to its legal manufacturer." ;
                 rdfs:label "has manufacturer" .


###  http://www.uoc.edu/knowledgeManagement/eu-medical-devices#hasRegulatoryFramework
:hasRegulatoryFramework rdf:type owl:ObjectProperty ;
                        rdfs:domain :Device ;
                        rdfs:range :RegulatoryFramework ;
                        rdfs:comment "Relates a device to the regulatory framework under which it is registered." ;
                        rdfs:label "has regulatory framework" .


###  http://www.uoc.edu/knowledgeManagement/eu-medical-devices#hasRiskCategory
:hasRiskCategory rdf:type owl:ObjectProperty ;
                 rdfs:domain :Risk ;
                 rdfs:range :CategoryConcept ;
                 rdfs:comment "Relates a risk to its controlled risk category." ;
                 rdfs:label "has risk category" .


###  http://www.uoc.edu/knowledgeManagement/eu-medical-devices#hasRiskClass
:hasRiskClass rdf:type owl:ObjectProperty ;
              rdfs:domain :Device ;
              rdfs:range :RiskClass ;
              rdfs:comment "Relates a device to its regulatory risk classification." ;
              rdfs:label "has risk class" .


###  http://www.uoc.edu/knowledgeManagement/eu-medical-devices#hasRiskProbability
:hasRiskProbability rdf:type owl:ObjectProperty ;
                    rdfs:domain :Risk ;
                    rdfs:range :ProbabilityConcept ;
                    rdfs:comment "Relates a risk to its probability level." ;
                    rdfs:label "has risk probability" .


###  http://www.uoc.edu/knowledgeManagement/eu-medical-devices#hasRiskSeverity
:hasRiskSeverity rdf:type owl:ObjectProperty ;
                 rdfs:domain :Risk ;
                 rdfs:range :SeverityConcept ;
                 rdfs:comment "Relates a risk to its severity level." ;
                 rdfs:label "has risk severity" .


###  http://www.uoc.edu/knowledgeManagement/eu-medical-devices#impactsDeviceType
:impactsDeviceType rdf:type owl:ObjectProperty ;
                   rdfs:domain :Risk ;
                   rdfs:range :DeviceType ;
                   rdfs:comment "Indicates the device type affected by a risk.." ;
                   rdfs:label "impacts device type" .


###  http://www.uoc.edu/knowledgeManagement/eu-medical-devices#involvesDevice
:involvesDevice rdf:type owl:ObjectProperty ;
                rdfs:domain :Incident ;
                rdfs:range :Device ;
                rdfs:comment "Links an incident to the device involved." ;
                rdfs:label "involves device" .


###  http://www.uoc.edu/knowledgeManagement/eu-medical-devices#involvesManufacturer
:involvesManufacturer rdf:type owl:ObjectProperty ;
                      rdfs:domain :Incident ;
                      rdfs:range :Manufacturer ;
                      rdfs:comment "Inferred relation linking an incident to the manufacturer of the involved device." ;
                      rdfs:label "involves manufacturer" .


###  http://www.uoc.edu/knowledgeManagement/eu-medical-devices#isReportedBy
:isReportedBy rdf:type owl:ObjectProperty ;
              rdfs:domain :Incident ;
              rdfs:range :Manufacturer ;
              rdfs:comment "Relates an incident to the manufacturer that reported it." ;
              rdfs:label "is reported by" .


###  http://www.uoc.edu/knowledgeManagement/eu-medical-devices#locatedInCountry
:locatedInCountry rdf:type owl:ObjectProperty ;
                  rdfs:domain :Organization ;
                  rdfs:range :Country ;
                  rdfs:comment "Relates an organization to the country where it is registered or located." ;
                  rdfs:label "located in country" .


###  http://www.uoc.edu/knowledgeManagement/eu-medical-devices#manufactures
:manufactures rdf:type owl:ObjectProperty ;
              rdfs:domain :Manufacturer ;
              rdfs:range :Device ;
              rdfs:comment "Relates a manufacturer to devices it manufactures." ;
              rdfs:label "manufactures" .


###  http://www.uoc.edu/knowledgeManagement/eu-medical-devices#reportedInCountry
:reportedInCountry rdf:type owl:ObjectProperty ;
                   rdfs:domain :Incident ;
                   rdfs:range :Country ;
                   rdfs:comment "Relates an incident to the country where it was reported." ;
                   rdfs:label "reported in country" .


#################################################################
#    Data properties
#################################################################

###  http://schema.org/description
<http://schema.org/description> rdf:type owl:DatatypeProperty ;
                                rdfs:range xsd:string ;
                                rdfs:comment "Textual description of the entity." ;
                                rdfs:label "description" .


###  http://schema.org/email
<http://schema.org/email> rdf:type owl:DatatypeProperty .


###  http://schema.org/gender
<http://schema.org/gender> rdf:type owl:DatatypeProperty .


###  http://schema.org/identifier
<http://schema.org/identifier> rdf:type owl:DatatypeProperty .


###  http://schema.org/name
<http://schema.org/name> rdf:type owl:DatatypeProperty ;
                         rdfs:range xsd:string ;
                         rdfs:comment "Human-readable name of the entity." ;
                         rdfs:label "name" .


###  http://www.uoc.edu/knowledgeManagement/eu-medical-devices#actionDate
:actionDate rdf:type owl:DatatypeProperty ;
            rdfs:domain :FieldSafetyCorrectiveAction ;
            rdfs:range xsd:date ;
            rdfs:comment "Date on which the corrective action was initiated." ;
            rdfs:label "action date" .


###  http://www.uoc.edu/knowledgeManagement/eu-medical-devices#authorizationNumber
:authorizationNumber rdf:type owl:DatatypeProperty ;
                     rdfs:subPropertyOf <http://schema.org/identifier> ;
                     rdfs:domain :Manufacturer ;
                     rdfs:range xsd:token ;
                     rdfs:comment "Authorization or registration number assigned to a manufacturer." ;
                     rdfs:label "authorization number" .


###  http://www.uoc.edu/knowledgeManagement/eu-medical-devices#closureDate
:closureDate rdf:type owl:DatatypeProperty ;
             rdfs:domain :FieldSafetyCorrectiveAction ;
             rdfs:range xsd:date ;
             rdfs:comment "Date on which the corrective action was closed." ;
             rdfs:label "clusure date" .


###  http://www.uoc.edu/knowledgeManagement/eu-medical-devices#detectionDate
:detectionDate rdf:type owl:DatatypeProperty ;
               rdfs:domain :Incident ;
               rdfs:range xsd:date ;
               rdfs:comment "Date on which the incident was detected." ;
               rdfs:label "detection date" .


###  http://www.uoc.edu/knowledgeManagement/eu-medical-devices#devicesAffected
:devicesAffected rdf:type owl:DatatypeProperty ;
                 rdfs:domain :FieldSafetyCorrectiveAction ;
                 rdfs:range xsd:string ;
                 rdfs:comment "Number or textual quantity of devices affected by a corrective action." ;
                 rdfs:label "devices affected" .


###  http://www.uoc.edu/knowledgeManagement/eu-medical-devices#eudamedFSCARef
:eudamedFSCARef rdf:type owl:DatatypeProperty ;
                rdfs:subPropertyOf <http://schema.org/identifier> ;
                rdfs:domain :FieldSafetyCorrectiveAction ;
                rdfs:range xsd:token ;
                rdfs:comment "Reference identifier assigned to a field safety corrective action." ;
                rdfs:label "EUDAMED FSCA reference" .


###  http://www.uoc.edu/knowledgeManagement/eu-medical-devices#eudamedIncidentRef
:eudamedIncidentRef rdf:type owl:DatatypeProperty ;
                    rdfs:subPropertyOf <http://schema.org/identifier> ;
                    rdfs:domain :Incident ;
                    rdfs:range xsd:token ;
                    rdfs:comment "Reference identifier assigned to an incident report." ;
                    rdfs:label "EUDAMED incident reference" .


###  http://www.uoc.edu/knowledgeManagement/eu-medical-devices#eudamedSRN
:eudamedSRN rdf:type owl:DatatypeProperty ;
            rdfs:domain :Manufacturer ;
            rdfs:range xsd:token ;
            rdfs:comment "Single Registration Number assigned to an economic operator in EUDAMED." ;
            rdfs:label "EUDAMED SRN" .


###  http://www.uoc.edu/knowledgeManagement/eu-medical-devices#eventDate
:eventDate rdf:type owl:DatatypeProperty ;
           rdfs:domain :Incident ;
           rdfs:range xsd:date ;
           rdfs:comment "Date on which the incident occurred." ;
           rdfs:label "event date" .


###  http://www.uoc.edu/knowledgeManagement/eu-medical-devices#imdrfCode
:imdrfCode rdf:type owl:DatatypeProperty ;
           rdfs:subPropertyOf <http://schema.org/identifier> ;
           rdfs:domain :Risk ;
           rdfs:range xsd:token ;
           rdfs:comment "Code identifying a risk according to an IMDRF-style classification." ;
           rdfs:label "IMDRF code" .


###  http://www.uoc.edu/knowledgeManagement/eu-medical-devices#intendedPurpose
:intendedPurpose rdf:type owl:DatatypeProperty ;
                 rdfs:domain :Device ;
                 rdfs:range xsd:string ;
                 rdfs:comment "Intended medical purpose or use of the device." ;
                 rdfs:label "intended purpose" .


###  http://www.uoc.edu/knowledgeManagement/eu-medical-devices#isActive
:isActive rdf:type owl:DatatypeProperty ;
          rdfs:domain :Device ;
          rdfs:range xsd:boolean ;
          rdfs:comment "Indicates whether the device is an active device according to the source data." ;
          rdfs:label "is active" .


###  http://www.uoc.edu/knowledgeManagement/eu-medical-devices#isImplantable
:isImplantable rdf:type owl:DatatypeProperty ;
               rdfs:domain :Device ;
               rdfs:range xsd:boolean ;
               rdfs:comment "Indicates whether the device is intended to be implanted in the human body." ;
               rdfs:label "is implantable" .


###  http://www.uoc.edu/knowledgeManagement/eu-medical-devices#isReusable
:isReusable rdf:type owl:DatatypeProperty ;
            rdfs:domain :Device ;
            rdfs:range xsd:boolean ;
            rdfs:comment "Indicates whether the device is intended for multiple uses." ;
            rdfs:label "is reusable" .


###  http://www.uoc.edu/knowledgeManagement/eu-medical-devices#outcome
:outcome rdf:type owl:DatatypeProperty ;
         rdfs:domain :Incident ;
         rdfs:range xsd:string ;
         rdfs:comment "Textual description of the incident outcome." ;
         rdfs:label "outcome" .


###  http://www.uoc.edu/knowledgeManagement/eu-medical-devices#patientAge
:patientAge rdf:type owl:DatatypeProperty ;
            rdfs:domain :Patient ;
            rdfs:range xsd:integer ;
            rdfs:comment "Age of the affected patient in years." ;
            rdfs:label "patient age" .


###  http://www.uoc.edu/knowledgeManagement/eu-medical-devices#reportDate
:reportDate rdf:type owl:DatatypeProperty ;
            rdfs:domain :Incident ;
            rdfs:range xsd:date ;
            rdfs:comment "Date on which the incident was officially reported." ;
            rdfs:label "report date" .


###  http://www.uoc.edu/knowledgeManagement/eu-medical-devices#scope
:scope rdf:type owl:DatatypeProperty ;
       rdfs:domain :FieldSafetyCorrectiveAction ;
       rdfs:range xsd:string ;
       rdfs:comment "Description of products, lots, units or users covered by a corrective action." ;
       rdfs:label "scope" .


###  http://www.uoc.edu/knowledgeManagement/eu-medical-devices#udiDI
:udiDI rdf:type owl:DatatypeProperty ;
       rdfs:subPropertyOf <http://schema.org/identifier> ;
       rdfs:domain :Device ;
       rdfs:range xsd:token ;
       rdfs:comment "Unique Device Identifier - Device Identifier." ;
       rdfs:label "UDI-DI" .


#################################################################
#    Classes
#################################################################

###  http://schema.org/MedicalDevice
<http://schema.org/MedicalDevice> rdf:type owl:Class .


###  http://schema.org/Person
<http://schema.org/Person> rdf:type owl:Class .


###  http://www.uoc.edu/knowledgeManagement/eu-medical-devices#CategoryConcept
:CategoryConcept rdf:type owl:Class ;
                 rdfs:comment "Controlled concept representing a category used to classify risks." ;
                 rdfs:label "Risk category concept" .


###  http://www.uoc.edu/knowledgeManagement/eu-medical-devices#CompetentAuthority
:CompetentAuthority rdf:type owl:Class ;
                    rdfs:subClassOf :Organization ;
                    rdfs:comment "Public authority responsible for medical device oversight in a country." ;
                    rdfs:label "Competent authority" .


###  http://www.uoc.edu/knowledgeManagement/eu-medical-devices#ContaminationRisk
:ContaminationRisk rdf:type owl:Class ;
                   rdfs:subClassOf :Risk ;
                   rdfs:comment "Risk related to contamination of device components, reagents or materials." ;
                   rdfs:label "Contamination risk" .


###  http://www.uoc.edu/knowledgeManagement/eu-medical-devices#CorrectedIncident
:CorrectedIncident rdf:type owl:Class ;
                   rdfs:comment "Incident inferred as having at least one associated corrective action." ;
                   rdfs:label "Corrected incident" .


###  http://www.uoc.edu/knowledgeManagement/eu-medical-devices#Country
:Country rdf:type owl:Class ;
         rdfs:comment "Nation in which a manufacturer, incident or corrective action is registered." ;
         rdfs:label "Country" .


###  http://www.uoc.edu/knowledgeManagement/eu-medical-devices#CybersecurityRisk
:CybersecurityRisk rdf:type owl:Class ;
                   rdfs:subClassOf :Risk ;
                   rdfs:comment "Risks arising from cybersecurity failures." ;
                   rdfs:label "Cybersecuty risk" .


###  http://www.uoc.edu/knowledgeManagement/eu-medical-devices#Device
:Device rdf:type owl:Class ;
        rdfs:subClassOf <http://schema.org/MedicalDevice> ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty :hasDeviceType ;
                          owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                          owl:onClass :DeviceType
                        ] ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty :hasManufacturer ;
                          owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                          owl:onClass :Manufacturer
                        ] ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty :hasRegulatoryFramework ;
                          owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                          owl:onClass :RegulatoryFramework
                        ] ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty :hasRiskClass ;
                          owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                          owl:onClass :RiskClass
                        ] ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty <http://schema.org/name> ;
                          owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                          owl:onDataRange xsd:string
                        ] ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty :intendedPurpose ;
                          owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                          owl:onDataRange xsd:string
                        ] ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty :isActive ;
                          owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                          owl:onDataRange xsd:boolean
                        ] ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty :isImplantable ;
                          owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                          owl:onDataRange xsd:boolean
                        ] ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty :isReusable ;
                          owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                          owl:onDataRange xsd:boolean
                        ] ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty :udiDI ;
                          owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                          owl:onDataRange xsd:token
                        ] ;
        rdfs:comment "Medical device placed on the European market under MDR or IVDR regulations." ;
        rdfs:label "Device" .


###  http://www.uoc.edu/knowledgeManagement/eu-medical-devices#DeviceType
:DeviceType rdf:type owl:Class ;
            rdfs:comment "Controlled classification describing the functional or structural type of device." ;
            rdfs:label "Device type" .


###  http://www.uoc.edu/knowledgeManagement/eu-medical-devices#DiagnosticRisk
:DiagnosticRisk rdf:type owl:Class ;
                rdfs:subClassOf :Risk ;
                rdfs:comment "Risk related to incorrect diagnostic results or interpretation." ;
                rdfs:label "Diagnostic risk" .


###  http://www.uoc.edu/knowledgeManagement/eu-medical-devices#FSCAStatusConcept
:FSCAStatusConcept rdf:type owl:Class ;
                   rdfs:comment "Controlled concept representing the status of a field safety corrective action." ;
                   rdfs:label "FCSA status concept" .


###  http://www.uoc.edu/knowledgeManagement/eu-medical-devices#FieldSafetyCorrectiveAction
:FieldSafetyCorrectiveAction rdf:type owl:Class ;
                             rdfs:subClassOf [ rdf:type owl:Restriction ;
                                               owl:onProperty :correctiveActionFor ;
                                               owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                               owl:onClass :Incident
                                             ] ,
                                             [ rdf:type owl:Restriction ;
                                               owl:onProperty :hasFSCAStatus ;
                                               owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                               owl:onClass :FSCAStatusConcept
                                             ] ,
                                             [ rdf:type owl:Restriction ;
                                               owl:onProperty <http://schema.org/description> ;
                                               owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                               owl:onDataRange xsd:string
                                             ] ,
                                             [ rdf:type owl:Restriction ;
                                               owl:onProperty :actionDate ;
                                               owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                               owl:onDataRange xsd:date
                                             ] ,
                                             [ rdf:type owl:Restriction ;
                                               owl:onProperty :devicesAffected ;
                                               owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                               owl:onDataRange xsd:string
                                             ] ,
                                             [ rdf:type owl:Restriction ;
                                               owl:onProperty :eudamedFSCARef ;
                                               owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                               owl:onDataRange xsd:token
                                             ] ,
                                             [ rdf:type owl:Restriction ;
                                               owl:onProperty :scope ;
                                               owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                               owl:onDataRange xsd:string
                                             ] ,
                                             [ rdf:type owl:Restriction ;
                                               owl:onProperty :closureDate ;
                                               owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                               owl:onDataRange xsd:date
                                             ] ;
                             rdfs:comment "Corrective measure taken to reduce risks associated with marketed devices." ;
                             rdfs:label "Field safety corrective action" .


###  http://www.uoc.edu/knowledgeManagement/eu-medical-devices#HighRiskDevice
:HighRiskDevice rdf:type owl:Class ;
                rdfs:comment "Device inferred as high risk according to its regulatory risk class." ;
                rdfs:label "High-risk device" .


###  http://www.uoc.edu/knowledgeManagement/eu-medical-devices#IVDDevice
:IVDDevice rdf:type owl:Class ;
           rdfs:subClassOf :Device ;
           owl:disjointWith :MDRDevice ;
           rdfs:comment "In vitro diagnostic device regulated under the IVDR regulation." ;
           rdfs:label "IVD device" .


###  http://www.uoc.edu/knowledgeManagement/eu-medical-devices#InSituCorrection
:InSituCorrection rdf:type owl:Class ;
                  rdfs:subClassOf :FieldSafetyCorrectiveAction ;
                  owl:disjointWith :Recall ,
                                   :SafetyAlert ,
                                   :UserNotice ;
                  rdfs:comment "Corrective action applied while the device remains in use or in place." ;
                  rdfs:label "In situ correction" .


###  http://www.uoc.edu/knowledgeManagement/eu-medical-devices#Incident
:Incident rdf:type owl:Class ;
          rdfs:subClassOf [ rdf:type owl:Restriction ;
                            owl:onProperty :involvesDevice ;
                            owl:someValuesFrom :Device
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :associatedRisk ;
                            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                            owl:onClass :Risk
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :isReportedBy ;
                            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                            owl:onClass :Manufacturer
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :reportedInCountry ;
                            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                            owl:onClass :Country
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :affectedPatient ;
                            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                            owl:onClass :Patient
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty <http://schema.org/description> ;
                            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                            owl:onDataRange xsd:string
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :detectionDate ;
                            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                            owl:onDataRange xsd:date
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :eudamedIncidentRef ;
                            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                            owl:onDataRange xsd:token
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :eventDate ;
                            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                            owl:onDataRange xsd:date
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :outcome ;
                            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                            owl:onDataRange xsd:string
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :reportDate ;
                            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                            owl:onDataRange xsd:date
                          ] ;
          rdfs:comment "Reported event involving a medical device that may cause harm or malfunction." ;
          rdfs:label "Incident" .


###  http://www.uoc.edu/knowledgeManagement/eu-medical-devices#InjuryRisk
:InjuryRisk rdf:type owl:Class ;
            rdfs:subClassOf :Risk ;
            rdfs:comment "Risk that may result in patient injury or deterioration of health." ;
            rdfs:label "Injury risk" .


###  http://www.uoc.edu/knowledgeManagement/eu-medical-devices#InterferenceRisk
:InterferenceRisk rdf:type owl:Class ;
                  rdfs:subClassOf :Risk ;
                  rdfs:comment "Risk related to electromagnetic, imaging or operational interference." ;
                  rdfs:label "Interference risk" .


###  http://www.uoc.edu/knowledgeManagement/eu-medical-devices#MDRDevice
:MDRDevice rdf:type owl:Class ;
           rdfs:subClassOf :Device ;
           rdfs:comment "Medical device regulated under the European MDR regulation." ;
           rdfs:label "MDR Device" .


###  http://www.uoc.edu/knowledgeManagement/eu-medical-devices#MalfunctionRisk
:MalfunctionRisk rdf:type owl:Class ;
                 rdfs:subClassOf :Risk ;
                 rdfs:comment "Risk related to device malfunction or failure to perform as intended." ;
                 rdfs:label "Malfunction risk" .


###  http://www.uoc.edu/knowledgeManagement/eu-medical-devices#Manufacturer
:Manufacturer rdf:type owl:Class ;
              rdfs:subClassOf :Organization ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty :hasCompetentAuthority ;
                                owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                owl:onClass :CompetentAuthority
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty :locatedInCountry ;
                                owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                owl:onClass :Country
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty <http://schema.org/email> ;
                                owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                owl:onDataRange xsd:string
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty :authorizationNumber ;
                                owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                owl:onDataRange xsd:token
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty :eudamedSRN ;
                                owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                owl:onDataRange xsd:token
                              ] ;
              rdfs:comment "Organization legally responsible for manufacturing a medical device." ;
              rdfs:label "Manufacturer" .


###  http://www.uoc.edu/knowledgeManagement/eu-medical-devices#MaterialRisk
:MaterialRisk rdf:type owl:Class ;
              rdfs:subClassOf :Risk ;
              rdfs:comment "Risk related to device materials, degradation, wear or corrosion." ;
              rdfs:label "Material risk" .


###  http://www.uoc.edu/knowledgeManagement/eu-medical-devices#NearMissIncident
:NearMissIncident rdf:type owl:Class ;
                  rdfs:subClassOf :Incident ;
                  rdfs:comment "Incident that could have led to harm but was avoided or did not occur." ;
                  rdfs:label "Near-miss incident" .


###  http://www.uoc.edu/knowledgeManagement/eu-medical-devices#Organization
:Organization rdf:type owl:Class ;
              rdfs:subClassOf <http://www.w3.org/ns/org#Organization> ;
              rdfs:comment "Legal or institutional entity involved in the medical device domain." ;
              rdfs:label "Organization" .


###  http://www.uoc.edu/knowledgeManagement/eu-medical-devices#Patient
:Patient rdf:type owl:Class ;
         rdfs:subClassOf <http://schema.org/Person> ,
                         [ rdf:type owl:Restriction ;
                           owl:onProperty <http://schema.org/gender> ;
                           owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                           owl:onDataRange xsd:string
                         ] ,
                         [ rdf:type owl:Restriction ;
                           owl:onProperty :patientAge ;
                           owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                           owl:onDataRange xsd:integer
                         ] ;
         rdfs:comment "Person affected by a medical device incident.Person affected by a medical device incident." ;
         rdfs:label "Patient" .


###  http://www.uoc.edu/knowledgeManagement/eu-medical-devices#ProbabilityConcept
:ProbabilityConcept rdf:type owl:Class ;
                    rdfs:comment "Controlled concept representing the probability level of a risk." ;
                    rdfs:label "Probability concept" .


###  http://www.uoc.edu/knowledgeManagement/eu-medical-devices#RadiationRisk
:RadiationRisk rdf:type owl:Class ;
               rdfs:subClassOf :Risk ;
               rdfs:comment "Risk related to unsafe or unintended radiation exposure." ;
               rdfs:label "Radiation risk" .


###  http://www.uoc.edu/knowledgeManagement/eu-medical-devices#Recall
:Recall rdf:type owl:Class ;
        rdfs:subClassOf :FieldSafetyCorrectiveAction ;
        owl:disjointWith :SafetyAlert ,
                         :UserNotice ;
        rdfs:comment "Corrective action involving withdrawal, replacement or removal of affected devices." ;
        rdfs:label "Recall" .


###  http://www.uoc.edu/knowledgeManagement/eu-medical-devices#RegulatoryFramework
:RegulatoryFramework rdf:type owl:Class ;
                     rdfs:comment "Regulation under which a device is registered or marketed." ;
                     rdfs:label "Regulatory framework" .


###  http://www.uoc.edu/knowledgeManagement/eu-medical-devices#ReportingEntity
:ReportingEntity rdf:type owl:Class ;
                 rdfs:subClassOf :Organization ;
                 rdfs:comment "Entity responsible for reporting an incident." ;
                 rdfs:label "Reporting entity" .


###  http://www.uoc.edu/knowledgeManagement/eu-medical-devices#Risk
:Risk rdf:type owl:Class ;
      rdfs:subClassOf [ rdf:type owl:Restriction ;
                        owl:onProperty :impactsDeviceType ;
                        owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                        owl:onClass :DeviceType
                      ] ,
                      [ rdf:type owl:Restriction ;
                        owl:onProperty :hasRiskCategory ;
                        owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                        owl:onClass :CategoryConcept
                      ] ,
                      [ rdf:type owl:Restriction ;
                        owl:onProperty :hasRiskProbability ;
                        owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                        owl:onClass :ProbabilityConcept
                      ] ,
                      [ rdf:type owl:Restriction ;
                        owl:onProperty :hasRiskSeverity ;
                        owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                        owl:onClass :SeverityConcept
                      ] ,
                      [ rdf:type owl:Restriction ;
                        owl:onProperty <http://schema.org/description> ;
                        owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                        owl:onDataRange xsd:string
                      ] ,
                      [ rdf:type owl:Restriction ;
                        owl:onProperty <http://schema.org/name> ;
                        owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                        owl:onDataRange xsd:string
                      ] ,
                      [ rdf:type owl:Restriction ;
                        owl:onProperty :imdrfCode ;
                        owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                        owl:onDataRange xsd:token
                      ] ;
      rdfs:comment "Potential hazard or adverse event associated with a medical device." ;
      rdfs:label "Risk" .


###  http://www.uoc.edu/knowledgeManagement/eu-medical-devices#RiskClass
:RiskClass rdf:type owl:Class ;
           rdfs:comment "Regulatory classification indicating the risk level of a medical device." ;
           rdfs:label "Risk class" .


###  http://www.uoc.edu/knowledgeManagement/eu-medical-devices#SafetyAlert
:SafetyAlert rdf:type owl:Class ;
             rdfs:subClassOf :FieldSafetyCorrectiveAction ;
             owl:disjointWith :UserNotice ;
             rdfs:comment "Corrective action communicating urgent safety information." ;
             rdfs:label "Safety alert" .


###  http://www.uoc.edu/knowledgeManagement/eu-medical-devices#SeriousIncident
:SeriousIncident rdf:type owl:Class ;
                 rdfs:subClassOf :Incident ;
                 rdfs:comment "Incident that caused or could have caused serious harm or health deterioration." ;
                 rdfs:label "Serious incident" .


###  http://www.uoc.edu/knowledgeManagement/eu-medical-devices#SeverityConcept
:SeverityConcept rdf:type owl:Class ;
                 rdfs:comment "Controlled concept representing the severity level of a risk." ;
                 rdfs:label "Severity concept" .


###  http://www.uoc.edu/knowledgeManagement/eu-medical-devices#SoftwareRisk
:SoftwareRisk rdf:type owl:Class ;
              rdfs:subClassOf :Risk ;
              rdfs:comment "Risk related to software malfunction, configuration or algorithmic error." ;
              rdfs:label "Software risk" .


###  http://www.uoc.edu/knowledgeManagement/eu-medical-devices#UserNotice
:UserNotice rdf:type owl:Class ;
            rdfs:subClassOf :FieldSafetyCorrectiveAction ;
            rdfs:comment "Corrective action consisting of notification." ;
            rdfs:label "User notice" .


